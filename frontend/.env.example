# API base URL — backend chạy trên port 8000 mặc định
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Proxy /api/diagnose/v2 (server Next.js) — ưu tiên hơn NEXT_PUBLIC
TUMINH_API_BASE=http://127.0.0.1:8000

# Tùy chọn: Google Places (bệnh viện gần hơn). Không có key → dùng OpenStreetMap Overpass (miễn phí).
# Ưu tiên server-only: GOOGLE_MAPS_API_KEY (không lộ ra client).
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Mã quốc gia mặc định cho số cấp cứu (VN = 115/113/114)
NEXT_PUBLIC_DEFAULT_COUNTRY=VN
